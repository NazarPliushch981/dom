    <script>

        class HtmlElement {
            constructor(tagName, isSelfClosing = false, textContent = "") {
                this.tagName = tagName;
                this.isSelfClosing = isSelfClosing;
                this.textContent = textContent;
                this.attributes = [];
                this.styles = [];
                this.children = [];
            }

            setAttr(name, value) {
                this.attributes.push({ name: name, value: value });
            }

            setStyle(name, value) {
                this.styles.push({ name: name, value: value });
            }

            append(element) {
                this.children.push(element);
            }

            prepend(element) {
                this.children.unshift(element);
            }

            getHtml() {
                let attrsStr = "";
                for (let i = 0; i < this.attributes.length; i++) {
                    attrsStr += ` ${this.attributes[i].name}="${this.attributes[i].value}"`;
                }

                if (this.styles.length > 0) {
                    let stylesStr = "";
                    for (let i = 0; i < this.styles.length; i++) {
                        stylesStr += `${this.styles[i].name}: ${this.styles[i].value}; `;
                    }
                    attrsStr += ` style="${stylesStr.trim()}"`;
                }

                if (this.isSelfClosing) {
                    return `<${this.tagName}${attrsStr}>\n`;
                }

                let childrenHtml = "";
                for (let i = 0; i < this.children.length; i++) {
                    childrenHtml += this.children[i].getHtml();
                }

                return `<${this.tagName}${attrsStr}>${this.textContent}${childrenHtml}</${this.tagName}>\n`;
            }
        }

